[
  {
    "key": "executive_story",
    "name": "IBOBS Executive Story",
    "timeRange": "-30m",
    "charts": [
      {
        "name": "Customer Support Response Latency",
        "type": "time",
        "programText": "A = data('latency_latest_ms', filter=filter('app.business_transaction', 'customer_support_response')).mean().publish(label='Latency')",
        "grid": { "width": 6, "height": 1, "row": 0, "column": 0 }
      },
      {
        "name": "Affected Sessions",
        "type": "single_value",
        "programText": "A = data('affected_sessions', filter=filter('deployment.environment', '{{deployment_environment}}')).publish(label='Sessions')",
        "grid": { "width": 6, "height": 1, "row": 0, "column": 6 }
      }
    ]
  },
  {
    "key": "business_transactions",
    "name": "IBOBS Business Transactions",
    "timeRange": "-30m",
