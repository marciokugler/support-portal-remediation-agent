      {
        "name": "Latency by Business Transaction",
        "type": "time",
        "programText": "A = data('latency_latest_ms', filter=filter('deployment.environment', '{{deployment_environment}}')).mean(by=['app.business_transaction']).publish(label='Latency')",
        "grid": { "width": 12, "height": 1, "row": 0, "column": 0 }
      },
      {
        "name": "Error Rate by Business Transaction",
        "type": "time",
        "programText": "A = data('errors', filter=filter('deployment.environment', '{{deployment_environment}}')).sum(by=['app.business_transaction'])\nB = data('requests', filter=filter('deployment.environment', '{{deployment_environment}}')).sum(by=['app.business_transaction'])\nC = (A / B).publish(label='Error Rate')",
        "grid": { "width": 12, "height": 1, "row": 1, "column": 0 }
      }
    ]
  },
